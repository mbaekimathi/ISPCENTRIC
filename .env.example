# ISPCENTRIC environment
# On cPanel (/home*/...), the app auto-detects hosted mode:
#   DEBUG=False, ALLOWED_HOSTS=*, CSRF from request, MySQL host=localhost,
#   no auto-create DB, no auto-migrate, media served by app.
# You only need MySQL credentials below (from cPanel → MySQL Databases).

DJANGO_HOSTED=auto

MYSQL_USER=richcomc_dbuser
MYSQL_PASSWORD=your-db-password
MYSQL_DATABASE=richcomc_dbname

# Optional overrides (usually leave unset on cPanel):
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=auto
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_CONN_MAX_AGE=60

# --- Local XAMPP only (set DJANGO_HOSTED=local) ---
# DJANGO_HOSTED=local
# DJANGO_DEBUG=True
# MYSQL_HOST=127.0.0.1
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=ISPCENTRIC

# Optional: Google Places autocomplete for MikroTik location search.
# Requires Places API + billing enabled on the Google Cloud project.
# If unset or denied, OpenStreetMap Nominatim is used automatically.
# GOOGLE_MAPS_API_KEY=
